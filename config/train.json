{
  "training": {
    "desc": "spanf_x2_realesrgan",
    "num_workers": 16,
    "save_dir": "checkpoints/run_{timestamp}_{desc}",
    "log_interval": 100,
    "save_interval": 5000,
    "val_interval": 5000,
    "device": "auto",
    "seed": 1234,
    "resume": null,
    "amp": true,
    "ema_decay": 0.999,
    "clip_grad_norm": 0.0,
    "drop_last": false,
    "cudnn_benchmark": true,
    "stage1": {
      "enabled": true,
      "total_steps": 250000,
      "warmup_steps": 0,
      "max_lr": 0.0002,
      "batch_size": 16,
      "optimizer_g": {
        "type": "adam",
        "betas": [0.9, 0.99],
        "weight_decay": 0.0
      },
      "scheduler": {
        "type": "multistep",
        "milestones": [250000],
        "gamma": 0.5
      },
      "usm": {
        "enabled": true,
        "radius": 51,
        "sigma": 0.0,
        "weight": 0.5,
        "threshold": 10.0,
        "pixel_target": true
      },
      "loss": {
        "pixel": {
          "type": "l1",
          "weight": 1.0
        }
      }
    },
    "stage2": {
      "enabled": true,
      "pretrained_generator": null,
      "total_steps": 100000,
      "warmup_steps": 0,
      "max_lr": 0.0001,
      "batch_size": 4,
      "optimizer_g": {
        "type": "adam",
        "betas": [0.9, 0.99],
        "weight_decay": 0.0
      },
      "optimizer_d": {
        "type": "adam",
        "betas": [0.9, 0.99],
        "weight_decay": 0.0
      },
      "scheduler": {
        "type": "multistep",
        "milestones": [100000],
        "gamma": 0.5
      },
      "usm": {
        "enabled": true,
        "radius": 51,
        "sigma": 0.0,
        "weight": 0.5,
        "threshold": 10.0,
        "pixel_target": true,
        "perceptual_target": true,
        "gan_target": false
      },
      "loss": {
        "pixel": {
          "type": "l1",
          "weight": 1.0
        },
        "perceptual": {
          "enabled": true,
          "type": "vgg19",
          "layer_weights": {
            "conv1_2": 0.1,
            "conv2_2": 0.1,
            "conv3_4": 1.0,
            "conv4_4": 1.0,
            "conv5_4": 1.0
          },
          "criterion": "l1",
          "use_input_norm": true,
          "range_norm": false,
          "weight": 1.0,
          "style_weight": 0.0
        },
        "gan": {
          "type": "vanilla",
          "weight": 0.1,
          "real_label": 1.0,
          "fake_label": 0.0
        }
      }
    }
  },
  "dataset": {
    "train_hr_dir": "/opt/data/private/dataset/rgb/DF2K/train",
    "train_lr_dir": null,
    "val_hr_dir": "/opt/data/private/dataset/rgb/DF2K/val",
    "val_lr_dir": null,
    "scale": 2,
    "lr_patch_size": 128,
    "filename_template": "{}",
    "recursive": true,
    "val_ratio": 0.05,
    "seed": 1234,
    "augment": true,
    "max_images": null,
    "degradation": {
      "type": "high_order",
      "validation_seed": 1234,
      "first_order": {
        "blur_probability": 0.8,
        "kernel_size": 15,
        "isotropic_probability": 0.5,
        "sigma_range": [0.2, 2.0],
        "rotation_range": [-3.1416, 3.1416],
        "resize_scale_range": [0.5, 1.5],
        "resize_direction_probabilities": [0.7, 0.2, 0.1],
        "resize_modes": ["bicubic", "bilinear", "lanczos"],
        "resize_mode_probabilities": [0.5, 0.25, 0.25],
        "noise_probability": 0.8,
        "gaussian_noise_probability": 0.6,
        "gray_noise_probability": 0.2,
        "gaussian_sigma_range": [1.0, 10.0],
        "poisson_peak_range": [100.0, 1000.0],
        "jpeg_probability": 0.8,
        "jpeg_quality_range": [60, 95],
        "jpeg_subsampling": 2
      },
      "second_order": {
        "blur_probability": 0.4,
        "kernel_size": 15,
        "isotropic_probability": 0.7,
        "sigma_range": [0.2, 1.2],
        "rotation_range": [-3.1416, 3.1416],
        "resize_scale_range": [0.7, 1.2],
        "resize_direction_probabilities": [0.4, 0.3, 0.3],
        "resize_modes": ["bicubic", "bilinear", "lanczos"],
        "resize_mode_probabilities": [0.5, 0.25, 0.25],
        "noise_probability": 0.8,
        "gaussian_noise_probability": 0.6,
        "gray_noise_probability": 0.2,
        "gaussian_sigma_range": [1.0, 8.0],
        "poisson_peak_range": [100.0, 1000.0],
        "jpeg_probability": 1.0,
        "jpeg_quality_range": [60, 95],
        "jpeg_subsampling": 2
      },
      "final": {
        "sinc_probability": 0.8,
        "sinc_kernel_size": 15,
        "sinc_cutoff_range": [0.3333, 1.0],
        "jpeg_before_resize_probability": 0.5,
        "resize_modes": ["bicubic", "bilinear", "lanczos"],
        "resize_mode_probabilities": [0.5, 0.25, 0.25]
      }
    }
  },
  "model": {
    "type": "spanf",
    "in_channels": 3,
    "out_channels": 3,
    "feature_channels": 32,
    "upscale": 2,
    "bias": true,
    "nearest_init": true
  },
  "discriminator": {
    "type": "unet_sn",
    "in_channels": 3,
    "feature_channels": 64,
    "skip_connection": true
  },
  "validation": {
    "crop_border": 2,
    "tile_size": 128,
    "tile_pad": 24,
    "lpips": {
      "enabled": true,
      "net": "alex"
    }
  }
}
