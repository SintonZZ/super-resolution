    "device": "auto",
    "seed": 1234,
    "resume": null,
    "amp": true,
    "clip_grad_norm": 0.0,
    "drop_last": false,
    "cudnn_benchmark": true
  },
  "dataset": {
    "train_hr_dir": "/opt/data/private/dataset/rgb/DF2K/train",
