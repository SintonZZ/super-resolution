{
  "training": {
    "desc": "spanf_x2_baseline",
    "total_epochs": 100,
    "cycle_length": 100,
    "max_lr": 0.0002,
    "min_lr": 0.000001,
    "betas": [0.9, 0.99],
    "weight_decay": 0.0,
    "batch_size": 16,
    "num_workers": 16,
    "save_dir": "checkpoints/run_{timestamp}_{desc}",
    "save_interval": 10,
